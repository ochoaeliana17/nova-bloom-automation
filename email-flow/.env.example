# Nova Bloom — Post-purchase email automation
# Copy this to .env and fill in your values

# Shopify
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# Mailchimp Transactional (Mandrill)
# Get from: https://mailchimp.com/developer/transactional/
MANDRILL_API_KEY=your_mandrill_api_key_here

# Sender identity (must be verified in Mandrill)
FROM_EMAIL=hello@novabloom.pt

# Server
PORT=3000
